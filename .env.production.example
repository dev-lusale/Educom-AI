# ═══════════════════════════════════════════════════════════════
# EduCom — Next.js Production Environment Variables (TEMPLATE)
# ───────────────────────────────────────────────────────────────
# DO NOT put real values here. This file is safe to commit.
# Set real values in the Vercel dashboard under:
#   Project → Settings → Environment Variables
# ═══════════════════════════════════════════════════════════════

# ── Database (Neon PostgreSQL) ────────────────────────────────────
DATABASE_PROVIDER=postgresql
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# ── NextAuth ──────────────────────────────────────────────────────
NEXTAUTH_URL=https://your-app.vercel.app
NEXTAUTH_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX

# ── Google OAuth ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=REPLACE_WITH_YOUR_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_YOUR_CLIENT_SECRET

# ── AI Backend (Railway FastAPI) ──────────────────────────────────
# This must be the public HTTPS URL Railway gives your backend service
AI_BACKEND_URL=https://your-backend.up.railway.app

# ── Google Gemini — used ONLY for /api/chat (server-side only) ────
# All other AI calls go through AI_BACKEND_URL — this key never
# reaches the browser.
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_KEY
GEMINI_MODEL=gemini-2.0-flash

# ── Gmail SMTP ────────────────────────────────────────────────────
GMAIL_USER=REPLACE_WITH_YOUR_GMAIL
GMAIL_APP_PASSWORD=REPLACE_WITH_APP_PASSWORD

# ── Admin Panel ───────────────────────────────────────────────────
ADMIN_JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
ADMIN_SETUP_KEY=REPLACE_WITH_STRONG_RANDOM_KEY
ADMIN_SETUP_DONE=false
