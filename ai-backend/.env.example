# ═══════════════════════════════════════════════════════════════
# Educom AI Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
ENVIRONMENT=production

# ── App URL ───────────────────────────────────────────────────────
# Public URL of the Next.js frontend — sent as HTTP-Referer to OpenRouter
APP_URL=https://educom-ai.vercel.app

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your Next.js frontend URLs)
ALLOWED_ORIGINS=http://localhost:3000,https://educom-ai.vercel.app

# ── OpenRouter — PRIMARY AI Provider ─────────────────────────────
# Get your free API key at: https://openrouter.ai/keys
# This key MUST stay on the backend only — never expose to the frontend.
OPENROUTER_API_KEY=sk-or-...

# ── Ollama — Local Fallback (only used if OPENROUTER_API_KEY is not set) ──
# Download Ollama at: https://ollama.com
# Pull a model with: ollama pull phi3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3
OLLAMA_FALLBACK_MODEL=mistral

# ── AI Generation Parameters ─────────────────────────────────────
# OpenRouter supports large output windows — 8192 tokens is a safe default
AI_MAX_TOKENS=8192
AI_TEMPERATURE=0.7
# Timeout in seconds — 60s is sufficient for most OpenRouter models
AI_TIMEOUT=60

# ── ChromaDB Vector Database ─────────────────────────────────────
CHROMA_PERSIST_DIR=./vector_db/chroma_store
CHROMA_COLLECTION_CURRICULUM=zambia_curriculum
CHROMA_COLLECTION_LESSON_PLANS=lesson_plan_samples

# ── Embeddings ────────────────────────────────────────────────────
# Uses sentence-transformers — no API key required
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Document Storage ─────────────────────────────────────────────
UPLOAD_DIR=./uploads
CURRICULUM_DOCS_DIR=./curriculum_docs
MAX_UPLOAD_SIZE_MB=50

# ── RAG Settings ─────────────────────────────────────────────────
# RAG_TOP_K: chunks retrieved per query. 8 works well for OpenRouter large-context models.
RAG_TOP_K=8
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200


# ═══════════════════════════════════════════════════════════════
# Deployment Notes
# ═══════════════════════════════════════════════════════════════
# 1. Set ALLOWED_ORIGINS to your production domain(s)
# 2. Set ENVIRONMENT=production and DEBUG=false
# 3. Deploy on Railway, Render, or Fly.io (any Python-capable host)
# 4. Set OPENROUTER_API_KEY as a secret environment variable in your
#    hosting provider's dashboard — never commit it to version control
# 5. Ollama fallback is optional — leave OLLAMA_* vars as defaults
#    if you are not running a local Ollama instance
