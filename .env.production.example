# ═══════════════════════════════════════════════════════════════
# EduCom — Next.js Production Environment Variables (TEMPLATE)
# ───────────────────────────────────────────────────────────────
# DO NOT put real values here. This file is safe to commit.
# Set real values in the Vercel dashboard under:
#   Project → Settings → Environment Variables
# ═══════════════════════════════════════════════════════════════

# ── Database (Supabase PostgreSQL) ───────────────────────────────
# Use the pooler connection string from Supabase → Project Settings → Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require

# ── NextAuth v5 ───────────────────────────────────────────────────
# next-auth v5 reads AUTH_SECRET and AUTH_URL (not NEXTAUTH_* keys)
AUTH_URL=https://your-app.vercel.app
AUTH_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX

# ── Google OAuth ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=REPLACE_WITH_YOUR_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_YOUR_CLIENT_SECRET

# ── AI Backend (Railway FastAPI) ──────────────────────────────────
# Public HTTPS URL Railway gives your backend service
AI_BACKEND_URL=https://your-backend.up.railway.app

# ── EduCom AI (OpenRouter) — server-side only, never reaches the browser ──
# Get your key at: https://openrouter.ai/keys — starts with sk-or-
OPENROUTER_API_KEY=REPLACE_WITH_YOUR_OPENROUTER_KEY

# ── Gmail SMTP ────────────────────────────────────────────────────
GMAIL_USER=REPLACE_WITH_YOUR_GMAIL
GMAIL_APP_PASSWORD=REPLACE_WITH_APP_PASSWORD

# ── Admin Panel ───────────────────────────────────────────────────
ADMIN_JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
ADMIN_SETUP_KEY=REPLACE_WITH_STRONG_RANDOM_KEY
ADMIN_SETUP_DONE=false
