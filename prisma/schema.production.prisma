// ─────────────────────────────────────────────────────────────────
// EduCom — PRODUCTION Prisma Schema (PostgreSQL / Neon)
//
// Usage (run once before first Vercel deploy):
//
//   $env:DATABASE_URL = "postgresql://user:pass@host/db?sslmode=require"
//   npx prisma db push --schema=prisma/schema.production.prisma
//
// After that, Vercel's build step uses the main schema.prisma (sqlite)
// only to generate the client. The actual DB operations hit Postgres
// via DATABASE_URL at runtime.
//
// Long-term: migrate to prisma migrate for proper migration history.
// ─────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth (NextAuth Prisma Adapter) ──────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(TEACHER)
  plan          Plan      @default(FREE)
  school        String?
  province      String?
  isActive           Boolean   @default(true)
  resetToken         String?
  resetTokenExpiry   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  lessonPlans   LessonPlan[]
  sharedPlans   SharedPlan[]
  likes         PlanLike[]
  saves         PlanSave[]
  subscriptions Subscription[]
  transactions  Transaction[]
  assessments   Assessment[]
  resources     Resource[]
  chatMessages  ChatMessage[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Subscriptions ───────────────────────────────────────────────

model Subscription {
  id             String             @id @default(cuid())
  userId         String
  plan           Plan               @default(PREMIUM)
  status         SubscriptionStatus @default(PENDING)
  startDate      DateTime?
  endDate        DateTime?
  amount         Float
  currency       String             @default("ZMW")
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model Transaction {
  id              String            @id @default(cuid())
  userId          String
  subscriptionId  String?
  transactionRef  String            @unique
  externalRef     String?
  paymentMethod   PaymentMethod
  amount          Float
  currency        String            @default("ZMW")
  status          TransactionStatus @default(PENDING)
  phoneNumber     String?
  bankName        String?
  accountNumber   String?
  receiptNumber   String?
  failureReason   String?
  metadata        String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
}

// ── Admin ───────────────────────────────────────────────────────

model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs AdminLog[]
}

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  target    String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

// ── Lesson Plans ────────────────────────────────────────────────

model LessonPlan {
  id         String   @id @default(cuid())
  userId     String
  grade      String
  subject    String
  topic      String
  duration   String
  enrollment String?
  date       String
  planData   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sharedPlan SharedPlan?
}

// ── Sharing ─────────────────────────────────────────────────────

model SharedPlan {
  id           String   @id @default(cuid())
  lessonPlanId String   @unique
  userId       String
  title        String
  description  String?
  grade        String
  subject      String
  topic        String
  isPublic     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lessonPlan LessonPlan @relation(fields: [lessonPlanId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes      PlanLike[]
  saves      PlanSave[]
}

model PlanLike {
  id           String   @id @default(cuid())
  userId       String
  sharedPlanId String
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  sharedPlan SharedPlan @relation(fields: [sharedPlanId], references: [id], onDelete: Cascade)

  @@unique([userId, sharedPlanId])
}

model PlanSave {
  id           String   @id @default(cuid())
  userId       String
  sharedPlanId String
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  sharedPlan SharedPlan @relation(fields: [sharedPlanId], references: [id], onDelete: Cascade)

  @@unique([userId, sharedPlanId])
}

// ── AI Assistant Chat ────────────────────────────────────────────

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Assessments ─────────────────────────────────────────────────

model Assessment {
  id             String   @id @default(cuid())
  userId         String
  grade          String
  subject        String
  topic          String
  assessmentType String
  assessmentData String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Teacher Resources ────────────────────────────────────────────

model Resource {
  id             String   @id @default(cuid())
  userId         String
  originalName   String
  storedName     String
  fileType       String
  fileSizeBytes  Int
  grade          String?
  subject        String?
  description    String?
  chunksCreated  Int      @default(0)
  downloadCount  Int      @default(0)
  collection     String   @default("user_resources")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Enums ───────────────────────────────────────────────────────

enum Role {
  TEACHER
  ADMIN
}

enum Plan {
  FREE
  PREMIUM
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
  SUSPENDED
}

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  MTN_MOMO
  AIRTEL_MONEY
  ZAMTEL_MONEY
  BANK_TRANSFER
}
