# ═══════════════════════════════════════════════════════════════
# Educom AI Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false
ENVIRONMENT=production

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your Next.js frontend URLs)
# Add your production domain here for deployment
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── Google Gemini — PRIMARY AI Provider ──────────────────────────
# Get a free API key at: https://aistudio.google.com/app/apikey
# This key MUST stay on the backend only — never expose to the frontend.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Ollama — Local Fallback (only used if GEMINI_API_KEY is not set) ──
# Download Ollama at: https://ollama.com
# Pull a model with: ollama pull phi3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3
OLLAMA_FALLBACK_MODEL=mistral

# AI Generation Parameters 
# Gemini 2.0 Flash supports up to 8192 output tokens
AI_MAX_TOKENS=8192
AI_TEMPERATURE=0.7
# Timeout in seconds — 60s is sufficient for Gemini
AI_TIMEOUT=60

# ChromaDB Vector Database 
CHROMA_PERSIST_DIR=./vector_db/chroma_store
CHROMA_COLLECTION_CURRICULUM=zambia_curriculum
CHROMA_COLLECTION_LESSON_PLANS=lesson_plan_samples

# Embeddings
# Uses ChromaDB's built-in ONNX model — no API key required
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Document Storage
UPLOAD_DIR=./uploads
CURRICULUM_DOCS_DIR=./curriculum_docs
MAX_UPLOAD_SIZE_MB=50

# RAG (Retrieval Augmented Generation) Settings 
# Gemini supports larger context than Ollama — higher top_k is fine
RAG_TOP_K=5
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=150


# Deployment Notes (Squarespace domain + cloud hosting)
# 1. Set ALLOWED_ORIGINS to your Squarespace/custom domain URL
# 2. Set ENVIRONMENT=production
# 3. Set DEBUG=false
# 4. Deploy on Railway, Render, or Fly.io (any Python-capable host)
# 5. Set all environment variables in your hosting provider's dashboard
# 6. The GEMINI_API_KEY must be set as a secret environment variable
# 7. For ~600 active users: use at least 1 vCPU / 1GB RAM instance